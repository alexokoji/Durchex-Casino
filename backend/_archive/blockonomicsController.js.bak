};

/**
 * Handle Blockonomics callback for USDT payments
 * Blockonomics sends this when a transaction is confirmed on-chain
 */
exports.handleBlockonomicsCallback = async (req, res) => {
    try {
        const { crypto, status, address, txid, confirmations, value } = req.body;

        console.log(`📦 Blockonomics webhook received:`, {
            crypto,
            status,
            address,
            txid,
            confirmations,
            value
        });

        // Only process USDT transactions
        if (crypto !== USDT_CONFIG.currency) {
            console.log(`⚠️ Skipping non-USDT transaction: ${crypto}`);
            return res.sendStatus(200); // Accept but ignore
        }

        // Find the crypto payment by deposit address
        const cryptoPayment = await CryptoPaymentV2Model.findOne({
            depositAddress: address,
            status: { $in: ['pending', 'processing'] }
        });

        if (!cryptoPayment) {
            console.log(`⚠️ No pending payment found for address: ${address}`);
            return res.sendStatus(200);
        }

        // Update transaction info
        cryptoPayment.transactionHash = txid;
        cryptoPayment.blockonomicsTransactionId = txid;
        cryptoPayment.amount = (value || 0) / Math.pow(10, USDT_CONFIG.decimals);
        cryptoPayment.confirmations = confirmations || 0;

        // Status from Blockonomics: 0=unconfirmed, 1=confirmed, 2=safe (multiple confirmations)
        if (confirmations >= USDT_CONFIG.requiredConfirmations) {
            cryptoPayment.status = 'confirmed';
            cryptoPayment.confirmedAt = new Date();

            console.log(`✅ USDT payment confirmed: ${txid}, Amount: ${cryptoPayment.amount}`);

            await cryptoPayment.save();

            // Update unified payment
            await UnifiedPaymentModel.findOneAndUpdate(
                { cryptoPaymentId: cryptoPayment._id },
                {
                    status: 'completed',
                    amountReceived: cryptoPayment.amount,
                    completedAt: new Date()
                }
            );

            // Add USDT funds to user account
            const user = await UserModel.findById(cryptoPayment.userId);
            if (user) {
                // Initialize wallet structure if needed
                if (!user.walletBalances) {
                    user.walletBalances = {};
                }

                // Add USDT balance
                if (!user.walletBalances.USDT) {
                    user.walletBalances.USDT = 0;
                }

                user.walletBalances.USDT += cryptoPayment.amount;

                // Also add to demo balance for testing if needed
                if (!user.demoBalance) user.demoBalance = { data: [] };

                let usdtBalance = user.demoBalance.data.find(b => b.currency === 'USDT');
                if (!usdtBalance) {
                    usdtBalance = { currency: 'USDT', balance: 0 };
                    user.demoBalance.data.push(usdtBalance);
                }

                usdtBalance.balance += cryptoPayment.amount;

                await user.save();

                console.log(`💰 User ${cryptoPayment.userId} credited with ${cryptoPayment.amount} USDT`);
            }

        } else {
            // Still pending more confirmations
            cryptoPayment.status = 'processing';
            await cryptoPayment.save();
            console.log(`⏳ USDT payment processing: ${confirmations}/${USDT_CONFIG.requiredConfirmations} confirmations`);
        }

        res.sendStatus(200);

    } catch (error) {
        console.error('❌ Blockonomics callback error:', error.message);
        // Always return 200 to acknowledge receipt
        res.sendStatus(200);
    }
};

