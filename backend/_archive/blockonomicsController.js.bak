const axios = require('axios');
const CryptoPaymentV2Model = require('../models/CryptoPaymentV2Model');
const UnifiedPaymentModel = require('../models/UnifiedPaymentModel');
const UserModel = require('../models/UserModel');

const BLOCKONOMICS_API_KEY = process.env.BLOCKONOMICS_API_KEY;
const BLOCKONOMICS_API_URL = process.env.BLOCKONOMICS_API_URL || 'https://www.blockonomics.co/api';
const BASE_URL = process.env.BASE_URL || 'http://localhost:5000';

// USDT Configuration (ERC20 Only)
const USDT_CONFIG = {
    currency: 'USDT',
    chain: 'ERC20',
    decimals: 6,
    requiredConfirmations: 6,
    minAmount: 1,
    maxAmount: 100000
};

/**
 * Generate USDT payment address using Blockonomics
 * Creates a unique wallet address for the user to deposit USDT
 */
exports.generateUSDTAddress = async (req, res) => {
    try {
        const { userId, isDemo } = req.body;

        if (!userId) {
            return res.status(400).json({
                status: false,
                message: 'Missing required field: userId'
            });
        }

        const user = await UserModel.findById(userId);
        if (!user) {
            return res.status(404).json({ status: false, message: 'User not found' });
        }

        // Check if local address generation is enabled (bypass Blockonomics)
        const useLocalAddress = process.env.USDT_USE_LOCAL_ADDRESS === 'true';

        // If demo mode or local address generation enabled, generate a mock address
        if (isDemo || useLocalAddress) {
            const mockAddress = `0x${Buffer.from(`USDT_${userId}_${Date.now()}`).toString('hex').substring(0, 40)}`;

            const cryptoPayment = new CryptoPaymentV2Model({
                userId,
                coinType: 'USDT',
                chain: 'ERC20',
                depositAddress: mockAddress,
                amount: 0,
                status: 'pending',
                isDemo: isDemo || useLocalAddress,
                requiredConfirmations: USDT_CONFIG.requiredConfirmations
            });

            const saved = await cryptoPayment.save();

            return res.json({
                status: true,
                message: useLocalAddress ? 'USDT deposit address generated (local)' : 'Demo USDT deposit address generated',
                data: {
                    paymentId: saved._id,
                    address: mockAddress,
                    currency: USDT_CONFIG.currency,
                    chain: USDT_CONFIG.chain,
                    decimals: USDT_CONFIG.decimals,
                    requiredConfirmations: USDT_CONFIG.requiredConfirmations,
                    qrCode: `https://api.qrserver.com/v1/create-qr-code/?data=${mockAddress}&size=300x300`,
                    status: 'pending',
                    isDemo: isDemo || useLocalAddress
                }
            });
        }

        // Generate real USDT address via Blockonomics API
        try {
            console.log('📡 Requesting USDT address from Blockonomics...');

            const response = await axios.post(
                `${BLOCKONOMICS_API_URL}/new_address`,
                {
                    crypto: USDT_CONFIG.currency, // 'USDT' for ERC20
                    addr_callback: `${BASE_URL}/api/v0/payments/blockonomics/callback`
                },
                {
                    headers: {
                        'Authorization': `Bearer ${BLOCKONOMICS_API_KEY}`,
                        'Content-Type': 'application/json'
                    }
                }
            );

            const { address, index } = response.data;

            if (!address) {
                throw new Error('No address returned from Blockonomics');
            }

            console.log(`✅ USDT address generated: ${address}`);

            // Create crypto payment record
            const cryptoPayment = new CryptoPaymentV2Model({
                userId,
                coinType: USDT_CONFIG.currency,
                chain: USDT_CONFIG.chain,
                depositAddress: address,
                amount: 0,
                status: 'pending',
                isDemo: false,
                requiredConfirmations: USDT_CONFIG.requiredConfirmations,
                blockonomicsTransactionId: null,
                blockonomicsIndex: index
            });

            const saved = await cryptoPayment.save();

            // Create unified payment record
            const unifiedPayment = new UnifiedPaymentModel({
                userId,
                paymentId: `CRYPTO-${saved._id}`,
                paymentMethod: 'crypto',
                cryptoPaymentId: saved._id,
                type: 'deposit',
                amountRequested: 0,
                currencyCode: USDT_CONFIG.currency,
                status: 'pending'
            });

            await unifiedPayment.save();

            res.json({
                status: true,
                message: 'USDT payment address generated successfully',
                data: {
                    paymentId: saved._id,
                    address,
                    currency: USDT_CONFIG.currency,
                    chain: USDT_CONFIG.chain,
                    decimals: USDT_CONFIG.decimals,
                    requiredConfirmations: USDT_CONFIG.requiredConfirmations,
                    qrCode: `https://api.qrserver.com/v1/create-qr-code/?data=${address}&size=300x300`,
                    instructions: `Send USDT (ERC20) to this address. Minimum: ${USDT_CONFIG.minAmount} USDT`,
                    status: 'pending'
                }
            });

        } catch (error) {
            console.error('❌ Blockonomics API error:', error.response?.data || error.message);
            const remoteMessage = error.response?.data?.error?.message || error.response?.data?.message || error.message;
            const errorCode = error.response?.data?.error?.code;
            
            // Fallback: If Blockonomics wallet is not configured (code 1041), generate demo address
            if (errorCode === 1041 || remoteMessage?.includes('wallet')) {
                console.log('⚠️ Blockonomics wallet not configured. Falling back to demo address generation...');
                const mockAddress = `0x${Buffer.from(`USDT_ERC20_${userId}_${Date.now()}`).toString('hex').substring(0, 40)}`;

                const cryptoPayment = new CryptoPaymentV2Model({
                    userId,
                    coinType: USDT_CONFIG.currency,
                    chain: USDT_CONFIG.chain,
                    depositAddress: mockAddress,
                    amount: 0,
                    status: 'pending',
                    isDemo: true,
                    requiredConfirmations: USDT_CONFIG.requiredConfirmations
                });

                const saved = await cryptoPayment.save();

                return res.json({
                    status: true,
                    message: 'USDT deposit address generated (fallback mode)',
                    data: {
                        paymentId: saved._id,
                        address: mockAddress,
                        currency: USDT_CONFIG.currency,
                        chain: USDT_CONFIG.chain,
                        decimals: USDT_CONFIG.decimals,
                        requiredConfirmations: USDT_CONFIG.requiredConfirmations,
                        qrCode: `https://api.qrserver.com/v1/create-qr-code/?data=${mockAddress}&size=300x300`,
                        instructions: `Send USDT (ERC20) to this address. Minimum: ${USDT_CONFIG.minAmount} USDT`,
                        status: 'pending',
                        isDemo: true,
                        warning: 'Demo mode: Blockonomics wallet not configured. Use simulate-deposit to test.'
                    }
                });
            }

            return res.status(500).json({
                status: false,
                message: 'Failed to generate USDT address',
                error: remoteMessage
            });
        }

    } catch (error) {
        console.error('❌ Generate USDT address error:', error.message);
        res.status(500).json({
            status: false,
            message: 'Failed to generate USDT address',
            error: error.message
        });
    }
};

// Legacy function for backward compatibility
exports.generateDepositAddress = exports.generateUSDTAddress;

/**
 * Get USDT payment status
 */
exports.getUSDTPaymentStatus = async (req, res) => {
    try {
        const { paymentId } = req.params;

        const cryptoPayment = await CryptoPaymentV2Model.findById(paymentId);
        if (!cryptoPayment) {
            return res.status(404).json({ status: false, message: 'Payment not found' });
        }

        // Check if expired (24 hours)
        if (cryptoPayment.status === 'pending' && cryptoPayment.expiresAt < new Date()) {
            cryptoPayment.status = 'expired';
            await cryptoPayment.save();
        }

        res.json({
            status: true,
            data: {
                paymentId: cryptoPayment._id,
                address: cryptoPayment.depositAddress,
                currency: cryptoPayment.coinType,
                chain: cryptoPayment.chain,
                amount: cryptoPayment.amount,
                confirmations: cryptoPayment.confirmations || 0,
                requiredConfirmations: cryptoPayment.requiredConfirmations,
                status: cryptoPayment.status,
                transactionHash: cryptoPayment.transactionHash,
                confirmedAt: cryptoPayment.confirmedAt,
                isDemo: cryptoPayment.isDemo
            }
        });

    } catch (error) {
        console.error('❌ Get payment status error:', error.message);
        res.status(500).json({
            status: false,
            message: 'Failed to get payment status',
            error: error.message
        });
    }
};

